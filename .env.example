# Copy this file to .env and fill in your keys
# Never commit .env to git

# Market data APIs (both have free tiers)
FMP_API_KEY=your_fmp_key_here
FINNHUB_API_KEY=your_finnhub_key_here

# OpenRouter — free NVIDIA model used by default (no cost)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Optional: switch to Anthropic instead (update provider in config.yaml)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: disable LLM entirely (pure data mode)
# LLM_ENABLED=false
